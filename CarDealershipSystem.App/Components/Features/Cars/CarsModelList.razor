@page "/cars-list"
@inject ApiService ApiService

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Inventory Management</h2>
        <button class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Car
        </button>
    </div>

    @if (responseModel == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading cars...</span>
            </div>
        </div>
    }
    else if (!responseModel.IsSuccess)
    {
        <div class="alert alert-danger shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Error:</strong> @responseModel.Message
        </div>
    }
    else if (responseModel.Data?.Cars == null || !responseModel.Data.Cars.Any())
    {
        <div class="alert alert-info shadow-sm text-center py-4" role="alert">
            <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
            No cars found in the dealership inventory.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col" style="width: 60px;">#</th>
                            <th scope="col">Brand</th>
                            <th scope="col">Model</th>
                            <th scope="col">Year</th>
                            <th scope="col">Price</th>
                            <th scope="col" class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            rowNo = 0;
                        }
                        @foreach (var car in responseModel.Data.Cars)
                        {
                            <tr>
                                <th scope="row">@(++rowNo)</th>
                                <td>@car.BrandName</td>
                                <td>@car.Modelnumber</td>
                                <td>@car.Year</td>
                                <td>@car.Price.ToString("C0")</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-secondary me-1" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>